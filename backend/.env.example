PORT=3000

# MongoDB - provide MONGODB_URI for a full connection string, or use individual vars
MONGODB_URI=
MONGODB_USER=your_mongodb_user
MONGODB_PASSWORD=your_mongodb_password
MONGODB_DBNAME=your_mongodb_dbname
MONGODB_HOST=cluster0.example.mongodb.net

# JWT Secret Key - MUST be set to a strong random value
JWT_SECRET=your_secret_key

# Email (SMTP) - for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_APP_PASS=your_app_password

# Frontend URL - used in password reset email links
FRONTEND_URL=http://localhost:4200

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# CORS - comma-separated origins, or * for all (development only)
CORS_ORIGIN=http://localhost:4200
